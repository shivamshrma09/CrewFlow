{
  "name": "crewflow",
  "version": "1.0.0",
  "description": "CrewFlow - The Ultimate Content Engine",
  "private": true,
  "scripts": {
    "install-all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "build": "cd frontend && npm run build",
    "dev": "concurrently \"npm --prefix backend run dev\" \"npm --prefix frontend run dev\"",
    "start": "npm --prefix frontend start"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "keywords": [
    "content-creation",
    "ai",
    "automation",
    "creators"
  ],
  "author": "Team VISION",
  "license": "MIT"
}
